# PR Resolver v3 — Environment Variables

# Telegram notifications (required for human escalation)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# GitHub bot identity (used for anti-loop detection)
BOT_GITHUB_USER=AdityaRuh

# Linear Integration (REQUIRED for ticket-driven mode)
# Generate at: https://linear.app/settings/api → Personal API Keys → Create Key
LINEAR_API_KEY=your-linear-api-key-here

# Optional: Default Linear team key (e.g., RP, SDR, TT)
# LINEAR_DEFAULT_TEAM=RP

# Optional: Override timeouts (seconds)
# OPENCLAW_TIMEOUT=600
# LLM_CLASSIFY_TIMEOUT=15
# LLM_SUMMARIZE_TIMEOUT=20
# LLM_REVIEW_TIMEOUT=120
